# Gemini API — get from aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase — get from your project Settings > API (or auto-provisioned by
# Vercel's Supabase integration if you connected a project through the
# Vercel dashboard). No NEXT_PUBLIC_ prefix — this app only talks to
# Supabase from the server.
SUPABASE_URL=
SUPABASE_ANON_KEY=
